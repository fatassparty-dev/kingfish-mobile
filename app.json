{
  "expo": {
    "name": "KingFish Bets",
    "slug": "kingfish-bets",
    "scheme": "kingfish",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/app-icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/images/crown-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#08090E"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.kingfishbets.app"
    },
    "android": {
      "package": "com.kingfishbets.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#08090E"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
