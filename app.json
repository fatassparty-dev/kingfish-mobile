{
  "expo": {
    "name": "KingFish Bets",
    "slug": "kingfish-bets",
    "scheme": "kingfish",
    "version": "1.0.3",
    "orientation": "default",
    "icon": "./assets/images/app-icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/images/crown-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#08090E"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.kingfishbets.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSPhotoLibraryUsageDescription": "KingFish uses your photo library so you can pick a bet-slip screenshot to grade.",
        "UISupportedInterfaceOrientations": [
          "UIInterfaceOrientationPortrait",
          "UIInterfaceOrientationPortraitUpsideDown",
          "UIInterfaceOrientationLandscapeLeft",
          "UIInterfaceOrientationLandscapeRight"
        ]
      },
      "buildNumber": "17"
    },
    "android": {
      "package": "com.kingfishbets.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#08090E"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-notifications",
      [
        "expo-image-picker",
        {
          "photosPermission": "KingFish uses your photo library so you can pick a bet-slip screenshot to grade."
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "organization": "kingfish-bets",
          "project": "react-native"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "52822283-8d79-4645-9fb9-52379c7d7382"
      }
    }
  }
}
